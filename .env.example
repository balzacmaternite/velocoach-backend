# ─────────────────────────────────────────────────────────────────
# VéloCoach — Variables d'environnement backend
# Copie ce fichier en .env et remplis les valeurs
# ─────────────────────────────────────────────────────────────────

# Strava API — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=REMPLACE_MOI
STRAVA_CLIENT_SECRET=REMPLACE_MOI

# URL de callback après connexion Strava
# En local :  http://localhost:3001/auth/callback
# En prod  :  https://ton-backend.railway.app/auth/callback
STRAVA_REDIRECT_URI=http://localhost:3001/auth/callback

# Token de validation du webhook Strava (n'importe quelle chaîne secrète)
STRAVA_WEBHOOK_VERIFY_TOKEN=velocoach_secret_webhook_2026

# URL du frontend React
FRONTEND_URL=http://localhost:5173

# Chemin vers la base SQLite
DB_PATH=./velocoach.db

# Port du serveur
PORT=3001
